# WebClient environment variables (Vite)
# Source of truth: ../.env — copy the VITE_* block here after updating root .env.
# VITE_ prefix is required for Vite to expose vars to the browser bundle.

VITE_AUTH_API_URL=http://localhost:8000
VITE_REPOSITORY_API_URL=http://localhost:8001
VITE_DATASETS_API_URL=http://localhost:8002
